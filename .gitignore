# KiCad Project Files
# Keep the core design files (.kicad_pcb, .kicad_sch, .kicad_pro)
# Ignore generated/build artifacts

# Backup and recovery files
*.kicad_pcb-bak
*.kicad_sch-bak
*.kicad_pcb~
*.kicad_sch~
*-bak
*~
.history/
*.history

# Generated output files
*.pdf
*.ps
*.svg
*.zip
*.tar.gz

# Generated manufacturing/Gerber files
**/Gerbers/
**/gerbers/
*.GBL
*.GBO
*.GBP
*.GBS
*.GKO
*.GML
*.GTO
*.GTP
*.GTS
*.TXT
*.XLN
*.DRF

# Generated pick and place files
*.csv
!.gitkeep  # Allow tracking empty directories if needed

# Netlist and component association files
*.net
*.cmp
*.kicad_pcb.kicad_pcb
**/sch_lib/

# CvPcb files
*.erc

# Eeschema (schematic) backup files
eeschema-*.cache

# Other KiCad generated files
*.kicad_pl
**/3D_Models/
fp-info-cache

# Temporary work files
**/work/
**/temp/
*.tmp

# KiCad lock files
*.lck

